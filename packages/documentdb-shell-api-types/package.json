{
  "name": "@vscode-documentdb/documentdb-shell-api-types",
  "version": "1.0.0",
  "description": "Shell API type definitions and method-to-command mapping for DocumentDB query playground IntelliSense",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p . && tsc -p tsconfig.scripts.json --noEmit",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "test": "jest --config jest.config.js",
    "prettier-fix": "prettier -w \"(scripts|src)/**/*.@(js|ts|jsx|tsx|json|md)\" \"./*.@(js|ts|jsx|tsx|json|md)\"",
    "verify": "ts-node scripts/verify-compatibility.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/vscode-documentdb",
    "directory": "packages/documentdb-shell-api-types"
  },
